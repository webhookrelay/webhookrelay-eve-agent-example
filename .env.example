# Copy to .env.local and fill in. .env.local is gitignored and is read by
# `eve dev`, `eve start`, and docker-compose (env_file).

# --- Model: Claude via Lightning AI (Anthropic-compatible Messages API) ---
# Any AI SDK provider works — see agent/agent.ts to swap it out.
LIGHTNING_API_KEY=
LIGHTNING_BASE_URL=https://lightning.ai/v1
LIGHTNING_MODEL=claude-sonnet-4-6

# --- Webhook Relay: token from https://my.webhookrelay.com/tokens ---
RELAY_KEY=
RELAY_SECRET=

# --- Optional: shared secret required on POST /eve/v1/webhook ---
# When set, callers must send an x-webhook-secret header with this value.
WEBHOOK_SECRET=

# --- Optional: where save_report writes reports (default ./reports) ---
REPORTS_DIR=
